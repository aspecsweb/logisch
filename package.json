{
  "name": "logisch",
  "version": "1.0.2",
  "description": "Generic Log Parsing",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./apache": {
      "types": "./dist/parsers/apache/index.d.ts",
      "import": "./dist/parsers/apache/index.js",
      "require": "./dist/parsers/apache/index.cjs"
    },
    "./android": {
      "types": "./dist/parsers/android/index.d.ts",
      "import": "./dist/parsers/android/index.js",
      "require": "./dist/parsers/android/index.cjs"
    },
    "./bgl": {
      "types": "./dist/parsers/bgl/index.d.ts",
      "import": "./dist/parsers/bgl/index.js",
      "require": "./dist/parsers/bgl/index.cjs"
    },
    "./fallback": {
      "types": "./dist/parsers/fallback/index.d.ts",
      "import": "./dist/parsers/fallback/index.js",
      "require": "./dist/parsers/fallback/index.cjs"
    },
    "./linux": {
      "types": "./dist/parsers/linux/index.d.ts",
      "import": "./dist/parsers/linux/index.js",
      "require": "./dist/parsers/linux/index.cjs"
    },
    "./macos": {
      "types": "./dist/parsers/macos/index.d.ts",
      "import": "./dist/parsers/macos/index.js",
      "require": "./dist/parsers/macos/index.cjs"
    },
    "./openssh": {
      "types": "./dist/parsers/openssh/index.d.ts",
      "import": "./dist/parsers/openssh/index.js",
      "require": "./dist/parsers/openssh/index.cjs"
    },
    "./proxifier": {
      "types": "./dist/parsers/proxifier/index.d.ts",
      "import": "./dist/parsers/proxifier/index.js",
      "require": "./dist/parsers/proxifier/index.cjs"
    },
    "./spark": {
      "types": "./dist/parsers/spark/index.d.ts",
      "import": "./dist/parsers/spark/index.js",
      "require": "./dist/parsers/spark/index.cjs"
    },
    "./thunderbird": {
      "types": "./dist/parsers/thunderbird/index.d.ts",
      "import": "./dist/parsers/thunderbird/index.js",
      "require": "./dist/parsers/thunderbird/index.cjs"
    },
    "./windows": {
      "types": "./dist/parsers/windows/index.d.ts",
      "import": "./dist/parsers/windows/index.js",
      "require": "./dist/parsers/windows/index.cjs"
    },
    "./zookeeper": {
      "types": "./dist/parsers/zookeeper/index.d.ts",
      "import": "./dist/parsers/zookeeper/index.js",
      "require": "./dist/parsers/zookeeper/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
